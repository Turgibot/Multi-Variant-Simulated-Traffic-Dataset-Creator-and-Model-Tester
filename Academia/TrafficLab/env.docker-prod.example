# Copy to your server as `.env` next to `docker-compose.prod.yml`, then:
#   chmod 600 .env
#   # edit placeholders, then:
#   docker compose -f docker-compose.prod.yml --env-file .env up -d
#
# POSTGRES_PASSWORD must be the same string you use for the password in DATABASE_URL.
# If the password contains # @ : / or spaces, URL-encode it in DATABASE_URL or wrap the whole value in double quotes.

POSTGRES_PASSWORD=CHANGE_ME_LONG_RANDOM
DATABASE_URL=postgresql://user:CHANGE_ME_LONG_RANDOM@db:5432/trafficlab

# Comma-separated origins the browser uses (scheme + host + port if non-default).
# Example: https://yourdomain.com or https://203.0.113.10
# No trailing slashes.
CORS_EXTRA_ORIGINS=https://YOUR_PUBLIC_ORIGIN
